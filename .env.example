# Local frontend/backend example values. Do not commit real secrets.

# Primary ML backend (Fly.dev):
# FASTAPI_BACKEND_URL=https://animalmind-backend.fly.dev

# Frontend URL for the ML backend (fallback is hardcoded in apiClient.ts):
# VITE_API_URL=https://animalmind-backend.fly.dev

# Local FastAPI backend (development only):
# FASTAPI_BACKEND_URL=http://localhost:8000
# VITE_API_URL=http://localhost:8000

# Fallback ML backend (Hugging Face Space):
# VITE_HF_SPACE_URL=https://firstoff-animalmind-backend.hf.space
